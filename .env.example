# Site Configuration
NEXT_PUBLIC_SITE_URL=https://safecertskills.co.uk
NEXT_PUBLIC_SITE_NAME=SafeCert Skills Ltd

# Contact Information
NEXT_PUBLIC_PHONE=0800 123 4567
NEXT_PUBLIC_EMAIL=info@safecertskills.co.uk
NEXT_PUBLIC_ADDRESS=Luton, United Kingdom

# Stripe Payment (TEST MODE)
# Get these from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Google Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# Google Maps API (Optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Form Submission (Optional - if you want to add contact form backend)
NEXT_PUBLIC_FORM_ENDPOINT=

# Database (Neon PostgreSQL) - REQUIRED
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth.js - REQUIRED
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email Service (Resend) - REQUIRED
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@safecertskills.co.uk"
